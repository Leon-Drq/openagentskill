# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Google Analytics 4 web stream. This ID is public by design.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Required for privileged automation/admin routes.
# Use either the modern Supabase secret key or the legacy service role key.
SUPABASE_SECRET_KEY=your-supabase-secret-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub API (for auto-indexer)
GITHUB_TOKEN=ghp_your_github_token

# Optional: Indexer authentication
# Required in production for indexer and blog-generation routes
INDEXER_SECRET=your-random-secret-string
INDEXER_RUN_TARGET=250
INDEXER_TARGET_TOTAL=20000
INDEXER_MIN_STARS=500
INDEXER_MAX_SEARCH_REQUESTS=30

# Optional: daily growth automation
# Runs GitHub hot-skill discovery, indexes approved skills, submits IndexNow URLs,
# queues X posts, and posts one queued update by default.
GROWTH_DAILY_TARGET_NEW=2
GROWTH_DAILY_TARGET_TOTAL=50000
GROWTH_DAILY_HOT_MIN_STARS=10
GROWTH_DAILY_HOT_LIMIT=24
GROWTH_DAILY_LOOKBACK_DAYS=21
GROWTH_DAILY_BULK_MIN_STARS=100
GROWTH_DAILY_BULK_MAX_SEARCH_REQUESTS=25
GROWTH_DAILY_BLOG_LIMIT=0
GROWTH_DAILY_X_QUEUE_LIMIT=8
GROWTH_DAILY_X_MIN_STARS=10
GROWTH_DAILY_AUTO_POST=true

# Optional: hourly quality maintenance radar. GitHub query windows rotate each
# hour; X is sampled every 6 hours by default to control API credit usage.
SKILL_RADAR_TARGET_NEW=2
SKILL_RADAR_MIN_STARS=10
SKILL_RADAR_GITHUB_MAX_QUERIES=4
SKILL_RADAR_X_MAX_QUERIES=1
SKILL_RADAR_X_SCAN_INTERVAL_HOURS=6
SKILL_RADAR_X_RESULTS_PER_QUERY=10
SKILL_RADAR_SEO_PER_RUN=1
SKILL_RADAR_X_QUEUE_LIMIT=2
SKILL_RADAR_AUTO_POST=false

# Optional: hourly SEO article drip
# Defaults to 2 posts/hour, which is 48/day, with a hard cap of 50/day.
SEO_DRIP_PER_RUN=2
SEO_DRIP_DAILY_LIMIT=50
SEO_DRIP_CANDIDATE_POOL=240

# Optional: Vercel AI Gateway model routing
# Defaults to deepseek/deepseek-v4-flash for cheaper review/generation.
OPENAGENTSKILL_AI_MODEL=deepseek/deepseek-v4-flash
# OPENAGENTSKILL_REVIEW_MODEL=deepseek/deepseek-v4-flash
# OPENAGENTSKILL_INDEXER_MODEL=deepseek/deepseek-v4-flash
# OPENAGENTSKILL_BLOG_MODEL=deepseek/deepseek-v4-flash

# Required in production for cron-triggered maintenance routes
CRON_SECRET=your-random-cron-secret-string

# Optional: X OAuth for authorized share/reply automation
# Keep these server-side only. Never expose client secrets or refresh tokens in browser code.
X_CLIENT_ID=your-x-oauth-client-id
X_CLIENT_SECRET=your-x-oauth-client-secret
X_ALLOWED_USERNAME=openagentskill
